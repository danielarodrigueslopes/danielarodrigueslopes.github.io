<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Gestão - DanielaDinih</title>

    <style>

      /* RESET */
      *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
        scroll-behavior:smooth;
      }

      /* MENU */
      nav{
        background:#ffffff;
        position:sticky;
        top:0;
        z-index:1000;
      }

      .menu{
        display:flex;
        justify-content:space-between;
        align-items:center;
        max-width:1000px;
        margin:auto;
        padding:15px;
        color:white;
      }

      .logo{
        font-size:20px;
        font-weight:bold;
      }

      nav ul{
        list-style:none;
        display:flex;
        gap:20px;
      }

      nav ul li a{
        color:#002eff;
        text-decoration:none;
        font-weight:bold;
        transition:0.3s;
      }

      nav ul li a:hover{
        opacity:0.7;
      }

      /* HERO */
      .hero{
        background:#f4f6f9;
        padding:80px 20px;
        text-align:center;
      }

      .hero h2{
        font-size:34px;
        margin-bottom:10px;
      }

      .hero p{
        color:#555;
        margin-bottom:20px;
      }

      .btn{
        background:#0d6efd;
        color:white;
        padding:12px 25px;
        border:none;
        border-radius:5px;
        text-decoration:none;
        font-size:16px;
        display:inline-block;
      }

      /* SEÇÕES */
      .container{
        padding:50px 20px;
        max-width:1000px;
        margin:auto;
      }

      .section-title{
        text-align:center;
        margin-bottom:30px;
        font-size:28px;
      }

      .cards{
        display:flex;
        flex-wrap:wrap;
        gap:20px;
        justify-content:center;
      }

      .card{
        background:white;
        padding:20px;
        border-radius:10px;
        box-shadow:0 0 10px rgba(0,0,0,0.1);
        width:250px;
        text-align:center;
        transition:0.3s;
      }

      .card:hover{
        transform:translateY(-5px);
      }

      .card h3{
        margin-bottom:10px;
        color:#0d6efd;
      }

      /* CONTATO */
      .contato{
        text-align:center;
        line-height:1.8;
      }

      /* RODAPÉ */
      footer{
        background:#0d6efd;
        color:white;
        text-align:center;
        padding:20px;
        margin-top:40px;
      }

      /* RESPONSIVO */
      @media(max-width:768px){
        .menu{
          flex-direction:column;
          gap:10px;
        }

        nav ul{
          flex-direction:column;
          align-items:center;
        }
      }

    </style>
  </head>

  <body>

    <!-- MENU -->
    <nav>
      <div class="menu">
        <div class="logo">
          <img src="https://danielarodrigueslopes.github.io/logo.png" alt="Girl in a jacket" width="450" height="160">
          
        
        </div>

        <ul>
          <li><a href="#inicio">Início</a></li>
          <li><a href="#funcionalidades">Funcionalidades</a></li>
          <li><a href="#sobre">Sobre</a></li>
          <li><a href="#contato">Contato</a></li>
        </ul>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero" id="inicio">
      <h2>Gestão Inteligente para Agentes de Saúde</h2>
      <p>Organize pacientes, visitas e atendimentos com eficiência.</p>
      <a href="#contato" class="btn">Solicitar Demonstração</a>
    </section>

    <!-- FUNCIONALIDADES -->
    <section class="container" id="funcionalidades">
      <h2 class="section-title">Funcionalidades</h2>

      <div class="cards">

        <div class="card">
          <h3>Cadastro de Pacientes</h3>
          <p>Registre informações completas e histórico de atendimentos.</p>
        </div>

        <div class="card">
          <h3>Ordem de Serviço</h3>
          <p>Controle visitas domiciliares e acompanhamentos.</p>
        </div>

        <div class="card">
          <h3>Prioridade</h3>
          <p>Organize atendimentos por nível de urgência.</p>
        </div>

        <div class="card">
          <h3>Agenda</h3>
          <p>Planeje e acompanhe visitas futuras.</p>
        </div>

        <div class="card">
          <h3>Relatórios</h3>
          <p>Visualize produtividade e dados importantes.</p>
        </div>

        <div class="card">
          <h3>Histórico</h3>
          <p>Acompanhe toda evolução dos pacientes.</p>
        </div>

      </div>
    </section>

    <!-- SOBRE -->
    <section class="container" id="sobre">
      <h2 class="section-title">Sobre o Sistema</h2>
      <p style="text-align:center;">
        Este sistema foi desenvolvido para auxiliar agentes comunitários de saúde na organização
        de atendimentos, controle de pacientes e registro de visitas domiciliares, trazendo mais
        eficiência e qualidade no acompanhamento da população.
      </p>
    </section>

    <!-- CONTATO -->
    <section class="container" id="contato">
      <h2 class="section-title">Contato</h2>

      <div class="contato">
        <p>Email: danieladinih123@gmail.com</p>
        <p>Telefone: (33) 98419-7306</p>
      </div>

    </section>

    <!-- RODAPÉ -->
    <footer>
      <p>© 2026 - Sistema DanielaDinih</p>
    </footer>

  </body>
</html>
